{
  "name": "tracking-validator",
  "version": "1.0.2",
  "description": "TSE Tracking Validator — Internal Tool",
  "main": "main.js",
  "scripts": {
    "start":     "electron .",
    "dev":       "electron . --dev",
    "build:mac": "electron-builder --mac",
    "release":   "electron-builder --mac --publish always"
  },
  "dependencies": {
    "playwright":                     "^1.42.0",
    "playwright-extra":               "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "csv-parse":                      "^5.5.3"
  },
  "devDependencies": {
    "electron":         "^30.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId":       "com.impact.tse.tracking-validator",
    "productName": "Tracking Validator",
    "copyright":   "TSE — impact.com",
    "directories": { "output": "dist" },
    "publish": {
      "provider": "github",
      "owner":    "ImpactInc",
      "repo":     "ts-tracking-validator"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "engine/**/*",
      "node_modules/**/*",
      "!node_modules/playwright/test/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/playwright/.local-browsers/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/playwright/.local-browsers",
        "to":   "chromium",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target":   [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "category": "public.app-category.developer-tools",
      "icon":     "assets/icon.icns"
    },
    "dmg": {
      "title":      "Tracking Validator ${version}",
      "background": null,
      "window":     { "width": 540, "height": 380 }
    }
  }
}